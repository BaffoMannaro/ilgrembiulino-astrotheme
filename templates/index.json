        "@media (max-width: 768px) {.tutto {background-size: 170%; background-position: bottom center; background-repeat: no-repeat; } .animated-eyes-container {transform: scale(0.4); transform-origin: bottom center; height: 400px; padding-bottom: 80px; }}"
      ],
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div class=\"tutto\"><div class=\"animated-eyes-container\">\n  <style> \n    .animated-eyes-container {\n      width: 100%;\nheight:650px;\n      display: flex;\n      justify-content: center;\n      align-items: end;\n      position: relative;\n      z-index: 1;\n    }\n\n    \n    .contain-eyes { \n      margin: 180px auto; \n      width: 400px; \n      position: relative;\n      z-index: 2;\n    } \n\n    \n    .outer-eye { \n      position: relative; \n      display: inline-block; \n      background: white !important; \n      border-radius: 50% !important; \n      width: 150px !important; \n      height: 130px !important; \n      margin: 0 10px;\n      overflow: visible !important;\ntransform: rotate(0.10turn);\n    } \n    \n    .outer-eye-2 { \n      left: 0px; \n    } \n    \n    .inner-eye { \n      position: absolute !important; \n      top: 45px !important;\n      left: 75px !important;\n      background: black !important; \n      border-top-left-radius: 50% !important; \nborder-bottom-left-radius: 40% !important; \nborder-bottom-right-radius: 30% !important; \nborder-top-right-radius: 30% !important; \n      width: 60px !important; \n      height: 60px !important; \n      animation: shifty 3s infinite !important; \n      z-index: 5 !important;\n      display: block !important;\n    } \n    \n    @keyframes shifty { \n      0% {\n        transform: translateX(0) translateY(0);\n      }\n      50% { \n        transform: translateX(-15px); \n      } \n      75% { \n        transform: translateY(-15px) translateX(-5px); \n      }\n      100% {\n        transform: translateX(0) translateY(0);\n      }\n    } \n  </style> \n  <div class=\"contain-eyes\">  \n    <div class=\"outer-eye\"> \n      <div class=\"inner-eye\"></div> \n    </div> \n    <div class=\"outer-eye outer-eye-2\"> \n      <div class=\"inner-eye\"></div> \n    </div> \n  </div>\n</div>\n</div>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
