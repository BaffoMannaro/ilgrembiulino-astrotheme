{% comment %}
  Animated Eyes Snippet
  Un'animazione di occhi che seguono il movimento
{% endcomment %}

<div class="animated-eyes-container" 
  {% if section.settings.background_image != blank %}
    style="background-image: url('{{ section.settings.background_image | img_url: 'master' }}');"
  {% endif %}
>
  <style> 
    .animated-eyes-container {
      width: 100%;
      padding: 80px 0;
      background-color: #4056f4;
      background-size: cover;
      background-position: center;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    
    /*Positioning details for container div*/ 
    .contain-eyes { 
      margin: 60px auto; 
      width: 255px; 
    } 
    
    .outer-eye { 
      /*Positioning*/ 
      position: relative; 
      display: inline-block; 
      /*Styling*/ 
      background: white; 
      border-radius: 50%; 
      /*Size*/ 
      width: 100px; 
      height: 100px; 
    } 
    
    .outer-eye-2 { 
      left: 50px; 
    } 
    
    .inner-eye { 
      /*Positioning*/ 
      position: absolute; 
      top: 50px; 
      left: 45px; 
      /*Styling*/ 
      background: #4056f4; 
      border-radius: 50%; 
      /*Size*/ 
      width: 35px; 
      height: 35px; 
      /*Assigns animation*/ 
      animation: shifty 3s infinite; 
    } 
    
    /*Begin animation details*/ 
    @keyframes shifty { 
      50% { 
        /*Moves pupils to left, change number to see what happens*/ 
        transform: translateX(-25px); 
      } 
      75% { 
        /*Moves pupils right and up, change numbers to see what happens*/ 
        transform: translateY(-30px) translateX(-10px); 
      } 
    } 
  </style> 
  <div class="contain-eyes">  
    <div class="outer-eye"> 
      <div class="inner-eye"></div> 
    </div> 
    <div class="outer-eye outer-eye-2"> 
      <div class="inner-eye"></div> 
    </div> 
  </div>
</div>