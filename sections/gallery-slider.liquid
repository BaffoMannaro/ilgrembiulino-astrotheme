{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}

<style>
  .gallery-slider {
    padding: 40px 0;
    background-color: {{ section.settings.background_color }};
    width: 100%;
    overflow: hidden;
  }
  
  .gallery-slider__container {
    width: 100%;
    padding: 0;
    position: relative;
  }
  
  .gallery-slider__title {
    margin-bottom: 25px;
    font-size: 2.5em;
    text-align: center;
    color: {{ section.settings.title_color }};
  }
  
  .gallery-slider__image-container {
    height: auto;
    display: flex;
    width: 100%;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }
  
  /* Overlay di sfumatura a sinistra */
  .gallery-slider__fade-left {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 15%;
    background: linear-gradient(to right, {{ section.settings.background_color }}, rgba({{ section.settings.background_color | color_to_rgb }}, 0));
    z-index: 2;
    pointer-events: none;
  }
  
  /* Overlay di sfumatura a destra */
  .gallery-slider__fade-right {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: 15%;
    background: linear-gradient(to left, {{ section.settings.background_color }}, rgba({{ section.settings.background_color | color_to_rgb }}, 0));
    z-index: 2;
    pointer-events: none;
  }
  
  .gallery-slider__slides {
    display: flex;
    width: 100%;
    animation: slides-left {{ section.settings.animation_duration }}s linear infinite;
  }
  
  .gallery-slider__slide {
    flex-shrink: 0; /* Impedisce alle immagini di restringersi */
    margin: 0 {{ section.settings.image_spacing }}px;
  }
  
  .gallery-slider__image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
  }
  
  .gallery-slider__image {
    width: {{ section.settings.image_width }}px;
    height: {{ section.settings.image_height }}px;
    object-fit: cover;
    transition: transform 0.3s ease-in-out;
  }
  
  .gallery-slider__image:hover {
    transform: scale(1.1);
  }
  
  .gallery-slider__caption {
    margin-top: 10px;
    text-align: center;
    color: {{ section.settings.caption_color }};
  }
  
  @keyframes slides-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-{{ section.settings.image_width }}px * {{ section.blocks.size }} - {{ section.settings.image_spacing | times: 2 | times: section.blocks.size }}px));
    }
  }
  
  @media screen and (max-width: 749px) {
    .gallery-slider__image {
      width: {{ section.settings.image_width_mobile }}px;
      height: {{ section.settings.image_height_mobile }}px;
    }
    
    @keyframes slides-left {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(calc(-{{ section.settings.image_width_mobile }}px * {{ section.blocks.size }} - {{ section.settings.image_spacing | times: 2 | times: section.blocks.size }}px));
      }
    }
  }
</style>

<section class="gallery-slider section-{{ section.id }}-padding">
  <div class="gallery-slider__container">
    {%- if section.settings.title != blank -%}
      <h2 class="gallery-slider__title {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.title | escape }}
      </h2>
    {%- endif -%}
    
    <div class="gallery-slider__image-container">
      <div class="gallery-slider__slides">
        {%- for block in section.blocks -%}
          <div class="gallery-slider__slide" {{ block.shopify_attributes }}>
            <div class="gallery-slider__image-wrapper">
              {%- if block.settings.image != blank -%}
                <img
                  srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                          {{ block.settings.image | image_url: width: 600 }} 600w,
                          {{ block.settings.image | image_url: width: 800 }} 800w,
                          {{ block.settings.image | image_url: width: 1200 }} 1200w"
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  sizes="(min-width: 750px) {{ section.settings.image_width }}px, {{ section.settings.image_width_mobile }}px"
                  alt="{{ block.settings.image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  class="gallery-slider__image"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg gallery-slider__image' }}
              {%- endif -%}
            </div>
            
            {%- if block.settings.caption != blank -%}
              <div class="gallery-slider__caption">
                <p>{{ block.settings.caption | escape }}</p>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
        
        {% comment %} Duplica le immagini per un'animazione continua {% endcomment %}
        {%- for block in section.blocks -%}
          <div class="gallery-slider__slide">
            <div class="gallery-slider__image-wrapper">
              {%- if block.settings.image != blank -%}
                <img
                  srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                          {{ block.settings.image | image_url: width: 600 }} 600w,
                          {{ block.settings.image | image_url: width: 800 }} 800w,
                          {{ block.settings.image | image_url: width: 1200 }} 1200w"
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  sizes="(min-width: 750px) {{ section.settings.image_width }}px, {{ section.settings.image_width_mobile }}px"
                  alt="{{ block.settings.image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  class="gallery-slider__image"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg gallery-slider__image' }}
              {%- endif -%}
            </div>
            
            {%- if block.settings.caption != blank -%}
              <div class="gallery-slider__caption">
                <p>{{ block.settings.caption | escape }}</p>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
    
    <!-- Elementi di sfumatura sui lati -->
    <div class="gallery-slider__fade-left"></div>
    <div class="gallery-slider__fade-right"></div>
  </div>
</section>

{% schema %}
{
  "name": "Gallery Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Image Slider",
      "label": "Titolo"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Medio"
        },
        {
          "value": "h1",
          "label": "Grande"
        },
        {
          "value": "h0",
          "label": "Extra grande"
        }
      ],
      "default": "h1",
      "label": "Dimensione del titolo"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#00171f",
      "label": "Colore sfondo"
    },
    {
      "type": "color",
      "id": "title_color",
      "default": "#ffffff",
      "label": "Colore titolo"
    },
    {
      "type": "color",
      "id": "caption_color",
      "default": "#ffffff",
      "label": "Colore didascalia"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 200,
      "max": 600,
      "step": 10,
      "default": 500,
      "unit": "px",
      "label": "Larghezza immagine (desktop)"
    },
    {
      "type": "range",
      "id": "image_height",
      "min": 200,
      "max": 600,
      "step": 10,
      "default": 450,
      "unit": "px",
      "label": "Altezza immagine (desktop)"
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "min": 100,
      "max": 400,
      "step": 10,
      "default": 300,
      "unit": "px",
      "label": "Larghezza immagine (mobile)"
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "min": 100,
      "max": 400,
      "step": 10,
      "default": 250,
      "unit": "px",
      "label": "Altezza immagine (mobile)"
    },
    {
      "type": "range",
      "id": "image_spacing",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 30,
      "unit": "px",
      "label": "Spazio tra le immagini"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 45,
      "unit": "px",
      "label": "Raggio bordo immagine"
    },
    {
      "type": "range",
      "id": "animation_duration",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "s",
      "label": "Durata animazione"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superiore",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferiore",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Didascalia",
          "info": "Opzionale"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}